echo Extracting netlist $RCN from $C ...
magic -dnull -noconsole << EOF
drc off
locking disable
crashbackups stop
box 0 0 0 0
load $C
select top cell
flatten myflat
load myflat
cellname delete $C
cellname rename myflat $C
select top cell
extract path extfiles
extract do unique
extract do resistance
extresist tolerance 10
extract all
ext2spice lvs
ext2spice cthresh 0.1
ext2spice extresist on
ext2spice -p extfiles -o $RCN
quit -noprompt
EOF
rm -r extfiles
if [ ! -f $RCN ]; then
  echo Error: Extracting netlist $RCN failed!
  exit 1
fi

echo $SN $PN $RCN created successfully!
exit 0
